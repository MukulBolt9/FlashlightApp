<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1A1A1A">

    <!-- Top row: icon + title + status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <ImageView
            android:id="@+id/notif_exp_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_flashlight_on"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Flashlight"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_exp_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFF"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="#2A2A2A" />

    </LinearLayout>

    <!-- Intensity bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_brightness_low"
            android:layout_marginEnd="8dp" />

        <ProgressBar
            android:id="@+id/notif_intensity_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="10"
            android:progress="5"
            android:progressTint="#FBBF24"
            android:progressBackgroundTint="#333333"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_brightness_high" />

    </LinearLayout>

    <!-- Intensity label -->
    <TextView
        android:id="@+id/notif_exp_intensity_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Intensity: 5/10"
        android:textColor="#888888"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="14dp" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Dimmer -->
        <TextView
            android:id="@+id/notif_btn_down"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="− Dimmer"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#242424"
            android:layout_marginEnd="6dp" />

        <!-- Toggle ON/OFF -->
        <TextView
            android:id="@+id/notif_btn_toggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Turn ON"
            android:textColor="#FBBF24"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#2A2200"
            android:layout_marginEnd="6dp" />

        <!-- Brighter -->
        <TextView
            android:id="@+id/notif_btn_up"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Brighter"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#242424" />

    </LinearLayout>

</LinearLayout>
